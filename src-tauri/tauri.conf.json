{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/tags/tauri-v2.0.0/crates/tauri-cli/schema.json",
  "productName": "SecBrain",
  "version": "0.5.0-beta.1",
  "identifier": "com.secbrain.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run prepare-bundle && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SecBrain",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../src": "secbrain_app/src",
      "../pyproject.toml": "secbrain_app/pyproject.toml",
      "../pipeline_manifest.json": "secbrain_app/pipeline_manifest.json",
      "../config.yaml": "secbrain_app/config.yaml",
      "../python_runtime/python": "python_runtime"
    }
  }
}
